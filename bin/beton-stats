#!/usr/bin/env python3
"""
beton-stats: rolling 24h counters for the verifier and bypass guard.

Storage: ~/.claude/.beton-stats.json. Schema:
  {
    "day": "YYYY-MM-DD",       # rolls over at local midnight
    "blocks": int,             # PostToolUse verifier blocks today
    "bypasses_refused": int,   # PreToolUse guard refusals today
    "clean": int,              # PostToolUse passes today
    "total_blocks": int,       # cumulative since install
    "total_refused": int,
    "total_clean": int
  }

Usage:
  beton-stats incr <counter>          # increment a counter
  beton-stats read [counter]          # read all or one counter as JSON
  beton-stats summary                 # one-line summary for statusline
  beton-stats reset                   # zero today's counters

Counters: blocks | bypasses_refused | clean

Designed to be called from shell hooks. Never raises; on error it returns
empty output and exit 0 so the calling hook stays silent.
"""
from __future__ import annotations
import json
import sys
from contextlib import contextmanager
from datetime import date
from pathlib import Path

try:
    import fcntl
    _HAS_FLOCK = True
except ImportError:  # Windows fallback: no locking, accept rare race.
    _HAS_FLOCK = False

STATS_PATH = Path.home() / ".claude" / ".beton-stats.json"
LOCK_PATH = Path.home() / ".claude" / ".beton-stats.lock"
COUNTERS = {"blocks", "bypasses_refused", "clean"}
TOTALS = {
    "blocks": "total_blocks",
    "bypasses_refused": "total_refused",
    "clean": "total_clean",
}


@contextmanager
def _locked():
    """Exclusive advisory file lock around read-modify-write.

    Without this, two PostToolUse or PreToolUse hooks firing in parallel can
    each read the same stats file, each increment, and the second write wipes
    the first increment. Measured ~10% loss at 50-way parallelism without the
    lock.
    """
    if not _HAS_FLOCK:
        yield
        return
    LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(LOCK_PATH, "w") as lf:
        fcntl.flock(lf.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf.fileno(), fcntl.LOCK_UN)


def load() -> dict:
    if not STATS_PATH.exists():
        return _fresh()
    try:
        data = json.loads(STATS_PATH.read_text())
    except (json.JSONDecodeError, OSError):
        return _fresh()
    today = date.today().isoformat()
    if data.get("day") != today:
        # Daily rollover: reset today counters, preserve totals.
        for c in COUNTERS:
            data[c] = 0
        data["day"] = today
    for c in COUNTERS:
        data.setdefault(c, 0)
    for t in TOTALS.values():
        data.setdefault(t, 0)
    return data


def _fresh() -> dict:
    d = {"day": date.today().isoformat()}
    for c in COUNTERS:
        d[c] = 0
    for t in TOTALS.values():
        d[t] = 0
    return d


def save(data: dict) -> None:
    STATS_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = STATS_PATH.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data))
    tmp.replace(STATS_PATH)


def incr(counter: str) -> None:
    if counter not in COUNTERS:
        return
    with _locked():
        data = load()
        data[counter] = data.get(counter, 0) + 1
        data[TOTALS[counter]] = data.get(TOTALS[counter], 0) + 1
        save(data)


def read(counter: str | None) -> None:
    data = load()
    if counter is None:
        print(json.dumps(data))
        return
    print(data.get(counter, 0))


def summary() -> None:
    """One-line, no newline. Empty if nothing happened today."""
    data = load()
    b = data.get("blocks", 0)
    r = data.get("bypasses_refused", 0)
    if b == 0 and r == 0:
        return
    parts = []
    if b:
        parts.append(f"{b} block" + ("s" if b != 1 else ""))
    if r:
        parts.append(f"{r} bypass" + ("es" if r != 1 else "") + " refused")
    sys.stdout.write(" ".join(parts))


def reset() -> None:
    data = load()
    for c in COUNTERS:
        data[c] = 0
    save(data)


def main() -> None:
    args = sys.argv[1:]
    if not args:
        sys.exit(0)
    cmd = args[0]
    try:
        if cmd == "incr" and len(args) == 2:
            incr(args[1])
        elif cmd == "read":
            read(args[1] if len(args) > 1 else None)
        elif cmd == "summary":
            summary()
        elif cmd == "reset":
            reset()
    except Exception:
        # Never fail a hook because stats are sticky. Swallow and exit 0.
        sys.exit(0)


if __name__ == "__main__":
    main()
