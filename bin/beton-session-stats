#!/usr/bin/env python3
"""Session diagnostics for a Claude Code project: cache hit rate, token usage, cost estimate."""

import argparse
import json
import sys
from pathlib import Path


# Pricing per 1M tokens (claude-sonnet-4-6)
PRICE_INPUT = 3.00
PRICE_OUTPUT = 15.00
PRICE_CACHE_CREATE = 3.75
PRICE_CACHE_READ = 0.30


def project_hash(path: str) -> str:
    """Convert project path to ~/.claude/projects/ directory name.

    Claude Code replaces every '/' with '-', including the leading one,
    so /Users/q/foo → -Users-q-foo  (leading dash is kept).
    """
    return Path(path).resolve().as_posix().replace("/", "-")


def find_usage(obj) -> dict | None:
    """Recursively find first dict containing 'input_tokens'."""
    if isinstance(obj, dict):
        if "input_tokens" in obj:
            return obj
        for v in obj.values():
            result = find_usage(v)
            if result is not None:
                return result
    return None


def parse_session(jsonl_path: Path) -> dict:
    """Accumulate token counts from a single JSONL session file."""
    totals = {
        "input": 0,
        "output": 0,
        "cache_creation": 0,
        "cache_read": 0,
        "cache_5m": 0,
        "cache_1h": 0,
    }
    with open(jsonl_path, encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            usage = find_usage(obj)
            if usage is None:
                continue
            totals["input"] += usage.get("input_tokens", 0)
            totals["output"] += usage.get("output_tokens", 0)
            totals["cache_creation"] += usage.get("cache_creation_input_tokens", 0)
            totals["cache_read"] += usage.get("cache_read_input_tokens", 0)
            cc = usage.get("cache_creation") or {}
            if isinstance(cc, dict):
                totals["cache_5m"] += cc.get("ephemeral_5m_input_tokens", 0)
                totals["cache_1h"] += cc.get("ephemeral_1h_input_tokens", 0)
    return totals


def compute_metrics(totals: dict) -> dict:
    inp = totals["input"]
    out = totals["output"]
    cc = totals["cache_creation"]
    cr = totals["cache_read"]

    total_input_tokens = inp + cc + cr
    cache_hit_rate = (cr / total_input_tokens * 100) if total_input_tokens > 0 else 0.0

    actual_cost = (
        inp * PRICE_INPUT / 1_000_000
        + out * PRICE_OUTPUT / 1_000_000
        + cc * PRICE_CACHE_CREATE / 1_000_000
        + cr * PRICE_CACHE_READ / 1_000_000
    )
    naive_cost = (
        total_input_tokens * PRICE_INPUT / 1_000_000
        + out * PRICE_OUTPUT / 1_000_000
    )
    savings_pct = ((naive_cost - actual_cost) / naive_cost * 100) if naive_cost > 0 else 0.0

    return {
        "cache_hit_rate": cache_hit_rate,
        "actual_cost": actual_cost,
        "naive_cost": naive_cost,
        "savings_pct": savings_pct,
    }


def print_report(project_path: str, sessions_found: int, sessions_requested: int, totals: dict) -> None:
    m = compute_metrics(totals)

    cc = totals["cache_creation"]
    c5 = totals["cache_5m"]
    c1 = totals["cache_1h"]
    has_breakdown = (c5 + c1) > 0
    pct_1h = (c1 / cc * 100) if cc > 0 else 0.0

    print(f"\nSession stats")
    print(f"Project: {project_path}")
    print(f"Sessions analyzed: {sessions_found} (last {sessions_requested} requested)")
    print()
    print("Token breakdown:")
    print(f"  Input (uncached):    {totals['input']:>12,}  tokens")
    print(f"  Cache creation:      {cc:>12,}  tokens  (write cost: 1.25x for 5m, 2.0x for 1h)")
    if has_breakdown:
        print(f"    └─ ephemeral_5m:   {c5:>12,}  tokens")
        print(f"    └─ ephemeral_1h:   {c1:>12,}  tokens  ({pct_1h:.0f}% of writes)")
    print(f"  Cache read:          {totals['cache_read']:>12,}  tokens  (read cost: 0.10x)")
    print(f"  Output:              {totals['output']:>12,}  tokens")
    print()
    print(f"Cache hit rate: {m['cache_hit_rate']:.1f}%")
    if has_breakdown and cc > 0 and pct_1h < 30:
        print(f"  ⚠  1h-tier writes are only {pct_1h:.0f}% of cache creation.")
        print(f"     If you set ttl: 3600 explicitly and still see this, telemetry may be disabled")
        print(f"     (kills 1h TTL) or your prefix changes too often to amortize the 2x write cost.")
    print()
    print("Cost estimate:")
    print(f"  Actual:    ${m['actual_cost']:.4f}")
    print(f"  Naive:     ${m['naive_cost']:.4f}  (no caching)")
    print(f"  Savings:   {m['savings_pct']:.1f}%")
    print()


def scan_project(project_path: str, sessions_n: int) -> tuple[dict, int]:
    """Returns (aggregated totals, files_found)."""
    hash_dir = Path.home() / ".claude" / "projects" / project_hash(project_path)
    if not hash_dir.exists():
        return None, 0

    jsonl_files = sorted(hash_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    selected = jsonl_files[:sessions_n]

    if not selected:
        return {}, 0

    agg = {"input": 0, "output": 0, "cache_creation": 0, "cache_read": 0, "cache_5m": 0, "cache_1h": 0}
    for f in selected:
        t = parse_session(f)
        for k in agg:
            agg[k] += t[k]

    return agg, len(selected)


def main():
    parser = argparse.ArgumentParser(
        description="Session diagnostics for a Claude Code project: cache hit rate, token usage, cost estimate."
    )
    parser.add_argument(
        "--project",
        default=None,
        metavar="PATH",
        help="Project path to analyze (default: current working directory)",
    )
    parser.add_argument(
        "--sessions",
        type=int,
        default=10,
        metavar="N",
        help="Number of most-recent sessions to analyze (default: 10)",
    )
    parser.add_argument(
        "--all-projects",
        action="store_true",
        help="Scan all projects under ~/.claude/projects/",
    )
    args = parser.parse_args()

    claude_root = Path.home() / ".claude" / "projects"
    if not claude_root.exists():
        print(f"Error: {claude_root} does not exist. No Claude Code sessions found.", file=sys.stderr)
        sys.exit(1)

    if args.all_projects:
        for project_dir in sorted(claude_root.iterdir()):
            if not project_dir.is_dir():
                continue
            jsonl_files = sorted(project_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
            selected = jsonl_files[: args.sessions]
            if not selected:
                continue
            agg = {"input": 0, "output": 0, "cache_creation": 0, "cache_read": 0, "cache_5m": 0, "cache_1h": 0}
            for f in selected:
                t = parse_session(f)
                for k in agg:
                    agg[k] += t[k]
            approx_path = project_dir.name
            print_report(approx_path, len(selected), args.sessions, agg)
        sys.exit(0)

    project_path = args.project or str(Path.cwd())
    totals, found = scan_project(project_path, args.sessions)

    if totals is None:
        hash_name = project_hash(project_path)
        print(f"No sessions found for project {project_path}")
        print(f"  (looked in {claude_root / hash_name})")
        sys.exit(0)

    if found == 0:
        print(f"No sessions found for project {project_path}")
        sys.exit(0)

    print_report(project_path, found, args.sessions, totals)
    sys.exit(0)


if __name__ == "__main__":
    main()
