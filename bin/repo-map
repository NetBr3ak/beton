#!/usr/bin/env bash
# bin/repo-map [<root-dir>] [--budget <tokens>]
# Generates a compact symbol index of a repository.
# Output is capped at --budget tokens (default 1800), approximated as chars/4.
# Prefers ctags; falls back to ripgrep; last resort is a flat file listing.

set -euo pipefail

ROOT="${1:-.}"
BUDGET=1800
if [ "${2:-}" = "--budget" ] && [ -n "${3:-}" ]; then
  BUDGET="$3"
fi

MAX_CHARS=$(( BUDGET * 4 ))

collect_symbols() {
  local root="$1"
  if command -v ctags &>/dev/null && ctags --version 2>&1 | grep -qiE "universal|exuberant"; then
    ctags -R --fields=+n --output-format=json --languages=Python,JavaScript,TypeScript,Go,Rust \
      "${root}" 2>/dev/null \
    | python3 << 'PYEOF'
import json, sys, collections

symbols = collections.defaultdict(list)
for line in sys.stdin:
    try:
        t = json.loads(line)
        if t.get('_type') != 'tag':
            continue
        f = t.get('path', '')
        k = t.get('kind', '?')[:2]
        n = t.get('name', '')
        ln = t.get('line', 0)
        if f and n:
            symbols[f].append((k, n, ln))
    except Exception:
        continue

for f, tags in sorted(symbols.items()):
    if not tags:
        continue
    print(f"FILE: {f}")
    for kind, name, line in sorted(tags, key=lambda x: x[2]):
        print(f"  {kind} {name} :{line}")
PYEOF
  elif command -v rg &>/dev/null; then
    rg --no-heading -n \
      -e '^(def |class |function |export (default |async )?(function|class) |const [A-Z])' \
      --glob '*.py' --glob '*.ts' --glob '*.tsx' --glob '*.js' \
      "${root}" 2>/dev/null \
    | head -500 \
    | python3 -c '
import sys, re, collections
NAME_RX = re.compile(
    r"^\s*(?:export\s+(?:default\s+)?(?:async\s+)?)?"
    r"(def|class|function|const)\s+([A-Za-z_][A-Za-z0-9_]*)"
)
by_file = collections.defaultdict(list)
for ln in sys.stdin:
    parts = ln.rstrip("\n").split(":", 2)
    if len(parts) != 3:
        continue
    f, line, content = parts
    m = NAME_RX.match(content)
    kind = m.group(1) if m else "def"
    name = m.group(2) if m else content.strip().split()[0]
    short = {"def":"fn","class":"cl","function":"fn","const":"co"}.get(kind,"fn")
    by_file[f].append((short, name, line))
for f, syms in sorted(by_file.items()):
    print(f"FILE: {f}")
    for short, name, line in syms:
        print(f"  {short} {name} :{line}")
'
  else
    find "${root}" \
      \( -name "*.py" -o -name "*.ts" -o -name "*.tsx" -o -name "*.js" \) \
      -not -path "*/node_modules/*" \
      -not -path "*/.venv/*" \
      -not -path "*/__pycache__/*" \
      2>/dev/null | head -50 | while read -r f; do
      echo "FILE: ${f}"
    done
  fi
}

{
  printf '%s\n' "# repo-map"
  printf '# root: %s\n' "${ROOT}"
  printf '%s\n' "---"
  collect_symbols "${ROOT}"
} | head -c "${MAX_CHARS}"
